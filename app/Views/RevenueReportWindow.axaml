<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:rental_ps_smart_billing.ViewModels"
        xmlns:models="using:rental_ps_smart_billing.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="980" d:DesignHeight="620"
        x:Class="rental_ps_smart_billing.Views.RevenueReportWindow"
        x:DataType="vm:RevenueReportViewModel"
        Title="Laporan Pendapatan"
        Width="980" Height="620"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA">

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="Laporan Pendapatan"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#1A237E" />

            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0" Text="Dari" VerticalAlignment="Center" Foreground="#37474F" />
                <CalendarDatePicker Grid.Column="1"
                                   SelectedDate="{Binding FromDate}"
                                   Width="140"
                                   IsEnabled="{Binding !IsBusy}" />
                <TextBlock Grid.Column="2" Text="Sampai" VerticalAlignment="Center" Foreground="#37474F" />
                <CalendarDatePicker Grid.Column="3"
                                   SelectedDate="{Binding ToDate}"
                                   Width="140"
                                   IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="5"
                        Content="Tampilkan"
                        Command="{Binding LoadCommand}"
                        Background="#1565C0"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Padding="12,6"
                        IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="6"
                        Content="Hari Ini"
                        Command="{Binding LoadTodayShortcutCommand}"
                        Padding="12,6"
                        IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="7"
                        Content="Bulan Ini"
                        Command="{Binding LoadThisMonthCommand}"
                        Padding="12,6"
                        IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="8"
                        Content="Tutup"
                        Command="{Binding CloseCommand}"
                        Padding="12,6" />
            </Grid>

            <Border Background="White"
                    BorderBrush="#CFD8DC"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,10">
                <Grid ColumnDefinitions="*,*,*,Auto" ColumnSpacing="16">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Periode" Foreground="#78909C" FontSize="12" />
                        <TextBlock Text="{Binding PeriodDisplay}" FontWeight="SemiBold" Foreground="#37474F" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="Transaksi" Foreground="#78909C" FontSize="12" />
                        <TextBlock Text="{Binding SessionCountDisplay}" FontWeight="SemiBold" Foreground="#37474F" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="Total Pendapatan" Foreground="#78909C" FontSize="12" />
                        <TextBlock Text="{Binding TotalAmountDisplay}"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Foreground="#E65100" />
                    </StackPanel>
                    <Button Grid.Column="3"
                            Content="Export Excel"
                            Command="{Binding ExportExcelCommand}"
                            VerticalAlignment="Center"
                            Background="#2E7D32"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="14,8" />
                </Grid>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#1565C0"
                       IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#C62828"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <Border Background="White"
                BorderBrush="#CFD8DC"
                BorderThickness="1"
                CornerRadius="6">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="#ECEFF1"
                        BorderBrush="#CFD8DC"
                        BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <Grid ColumnDefinitions="140,140,120,110,*,120">
                        <TextBlock Grid.Column="0" Text="Selesai" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="Mulai" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="Unit TV" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="Customer" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="4" Text="Paket" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="5" Text="Jumlah" FontWeight="SemiBold" HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Items}"
                         IsEnabled="{Binding !IsBusy}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:RevenueReportItem">
                            <Border Padding="12,8"
                                    BorderBrush="#ECEFF1"
                                    BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="140,140,120,110,*,120">
                                    <TextBlock Grid.Column="0" Text="{Binding EndedLocalDisplay}" />
                                    <TextBlock Grid.Column="1" Text="{Binding StartedLocalDisplay}" />
                                    <TextBlock Grid.Column="2" Text="{Binding TvName}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding CustomerDisplay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="4" Text="{Binding PackageDisplay}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="5"
                                               Text="{Binding AmountDisplay}"
                                               HorizontalAlignment="Right"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </DockPanel>
</Window>
