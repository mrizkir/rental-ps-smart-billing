<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:rental_ps_smart_billing.ViewModels"
        xmlns:models="using:rental_ps_smart_billing.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="960" d:DesignHeight="520"
        x:Class="rental_ps_smart_billing.Views.SmartTvListWindow"
        x:DataType="vm:SmartTvListViewModel"
        Title="Daftar Smart TV"
        Width="960" Height="520"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA">

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Spacing="12" Margin="0,0,0,16">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <TextBlock Grid.Column="0"
                           Text="Daftar Smart TV"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#1A237E"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Tambah"
                        Command="{Binding AddSmartTvCommand}"
                        Background="#1565C0"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Padding="12,6"
                        IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="2"
                        Content="Edit"
                        Command="{Binding EditSmartTvCommand}"
                        Padding="12,6"
                        IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="3"
                        Content="Hapus"
                        Command="{Binding DeleteSmartTvCommand}"
                        Background="#C62828"
                        Foreground="White"
                        Padding="12,6"
                        IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="4"
                        Content="Test Koneksi"
                        Command="{Binding TestConnectionCommand}"
                        Padding="12,6"
                        IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="5"
                        Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Padding="12,6"
                        IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="6"
                        Content="Tutup"
                        Command="{Binding CloseCommand}"
                        Padding="12,6" />
            </Grid>

            <Border Background="#E3F2FD"
                    CornerRadius="6"
                    Padding="10,8"
                    IsVisible="{Binding TestMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <StackPanel Spacing="6">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Content="Salin"
                                Command="{Binding CopyTestMessageCommand}"
                                Margin="8,0,0,0"
                                VerticalAlignment="Top"
                                Padding="10,4" />
                        <TextBox Text="{Binding TestMessage}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MaxHeight="140"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="#0D47A1"
                                 FontFamily="Consolas,Courier New,monospace"
                                 FontSize="12"
                                 CaretBrush="#0D47A1" />
                    </DockPanel>
                    <TextBlock Text="{Binding CopyFeedback}"
                               Foreground="#2E7D32"
                               FontSize="11"
                               IsVisible="{Binding CopyFeedback, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#C62828"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
        </StackPanel>

        <Border Background="White"
                BorderBrush="#CFD8DC"
                BorderThickness="1"
                CornerRadius="6">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        Background="#ECEFF1"
                        BorderBrush="#CFD8DC"
                        BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <Grid ColumnDefinitions="120,70,100,110,140,55,70,100">
                        <TextBlock Grid.Column="0" Text="Nama" FontWeight="SemiBold" Foreground="#37474F" />
                        <TextBlock Grid.Column="1" Text="Merek" FontWeight="SemiBold" Foreground="#37474F" />
                        <TextBlock Grid.Column="2" Text="Model" FontWeight="SemiBold" Foreground="#37474F" />
                        <TextBlock Grid.Column="3" Text="IP" FontWeight="SemiBold" Foreground="#37474F" />
                        <TextBlock Grid.Column="4" Text="MAC" FontWeight="SemiBold" Foreground="#37474F" />
                        <TextBlock Grid.Column="5" Text="Port" FontWeight="SemiBold" Foreground="#37474F" />
                        <TextBlock Grid.Column="6" Text="Status" FontWeight="SemiBold" Foreground="#37474F" />
                        <TextBlock Grid.Column="7" Text="Test" FontWeight="SemiBold" Foreground="#37474F" />
                    </Grid>
                </Border>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding SmartTvs}"
                         SelectedItem="{Binding SelectedSmartTv}"
                         IsEnabled="{Binding !IsBusy}"
                         BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:SmartTvListItem">
                            <Border Padding="12,8"
                                    BorderBrush="#ECEFF1"
                                    BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="120,70,100,110,140,55,70,100">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Brand}" />
                                    <TextBlock Grid.Column="2" Text="{Binding ModelDisplay}" />
                                    <TextBlock Grid.Column="3" Text="{Binding IpAddress}" />
                                    <TextBlock Grid.Column="4" Text="{Binding MacAddress}" />
                                    <TextBlock Grid.Column="5" Text="{Binding WsPort}" />
                                    <TextBlock Grid.Column="6" Text="{Binding Status}" />
                                    <TextBlock Grid.Column="7" Text="{Binding LastTestDisplay}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </DockPanel>
</Window>
