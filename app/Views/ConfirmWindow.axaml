<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:rental_ps_smart_billing.ViewModels"
        x:Class="rental_ps_smart_billing.Views.ConfirmWindow"
        x:DataType="vm:ConfirmViewModel"
        Title="{Binding Title}"
        Width="400" Height="180"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#FAFAFA">

    <Border Margin="20" Padding="16" Background="White" CornerRadius="8">
        <Grid RowDefinitions="*,Auto" RowSpacing="16">
            <TextBlock Grid.Row="0"
                       Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="#37474F" />
            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Grid.Column="0"
                        Content="Batal"
                        Command="{Binding CancelCommand}"
                        Height="32" />
                <Button Grid.Column="1"
                        Content="Ya"
                        Command="{Binding ConfirmCommand}"
                        Height="32"
                        Background="#C62828"
                        Foreground="White"
                        FontWeight="SemiBold" />
            </Grid>
        </Grid>
    </Border>
</Window>
