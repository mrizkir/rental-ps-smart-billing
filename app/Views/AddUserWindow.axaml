<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:rental_ps_smart_billing.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="460" d:DesignHeight="520"
        x:Class="rental_ps_smart_billing.Views.AddUserWindow"
        x:DataType="vm:AddUserViewModel"
        Title="Tambah User"
        Width="460" Height="520"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#ECEFF1">

    <Border Margin="20"
            Padding="24"
            Background="White"
            CornerRadius="10">
        <StackPanel Spacing="14">
            <TextBlock Text="Tambah User Baru"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#1A237E" />

            <StackPanel Spacing="6">
                <TextBlock Text="Username" Foreground="#37474F" FontWeight="Medium" />
                <TextBox Text="{Binding Username}"
                         PlaceholderText="contoh: operator2"
                         IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Nama Tampilan" Foreground="#37474F" FontWeight="Medium" />
                <TextBox Text="{Binding DisplayName}"
                         PlaceholderText="contoh: Operator 2"
                         IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Role" Foreground="#37474F" FontWeight="Medium" />
                <ComboBox ItemsSource="{Binding Roles}"
                          SelectedItem="{Binding SelectedRole}"
                          IsEnabled="{Binding !IsBusy}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Password" Foreground="#37474F" FontWeight="Medium" />
                <TextBox Text="{Binding Password}"
                         PasswordChar="●"
                         PlaceholderText="Minimal 6 karakter"
                         IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Konfirmasi Password" Foreground="#37474F" FontWeight="Medium" />
                <TextBox Text="{Binding ConfirmPassword}"
                         PasswordChar="●"
                         PlaceholderText="Ulangi password"
                         IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#C62828"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                <Button Grid.Column="0"
                        Content="Batal"
                        Command="{Binding CancelCommand}"
                        Height="36"
                        IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="1"
                        Content="Simpan"
                        Command="{Binding SaveCommand}"
                        Height="36"
                        Background="#1565C0"
                        Foreground="White"
                        FontWeight="SemiBold"
                        IsEnabled="{Binding !IsBusy}" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
