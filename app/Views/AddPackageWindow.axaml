<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:rental_ps_smart_billing.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="460" d:DesignHeight="500"
        x:Class="rental_ps_smart_billing.Views.AddPackageWindow"
        x:DataType="vm:AddPackageViewModel"
        Title="Tambah Paket"
        Width="460" Height="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#ECEFF1">

    <Border Margin="20"
            Padding="24"
            Background="White"
            CornerRadius="10">
        <StackPanel Spacing="14">
            <TextBlock Text="Tambah Paket Baru"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#1A237E" />

            <StackPanel Spacing="6">
                <TextBlock Text="Tipe Paket" Foreground="#37474F" FontWeight="Medium" />
                <ComboBox ItemsSource="{Binding BillingModeOptions}"
                          SelectedItem="{Binding SelectedBillingMode}"
                          IsEnabled="{Binding !IsBusy}"
                          HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PackageBillingModeOption">
                            <TextBlock Text="{Binding Label}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Nama Paket" Foreground="#37474F" FontWeight="Medium" />
                <TextBox Text="{Binding Name}"
                         PlaceholderText="contoh: Free Play / Paket 60 Menit"
                         IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding IsFixedPackage}">
                <TextBlock Text="Durasi (menit)" Foreground="#37474F" FontWeight="Medium" />
                <TextBox Text="{Binding DurationMinutesText}"
                         PlaceholderText="contoh: 60"
                         IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="{Binding PriceLabel}" Foreground="#37474F" FontWeight="Medium" />
                <TextBox Text="{Binding PriceText}"
                         PlaceholderText="{Binding PricePlaceholder}"
                         IsEnabled="{Binding !IsBusy}" />
            </StackPanel>

            <TextBlock Text="Free Play: tagihan per menit saat BAYAR. Menit awal gratis diatur di appsettings (Billing:FreePlayGraceMinutes, default 5)."
                       Foreground="#546E7A"
                       TextWrapping="Wrap"
                       FontSize="12"
                       IsVisible="{Binding !IsFixedPackage}" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="#C62828"
                       TextWrapping="Wrap"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                <Button Grid.Column="0"
                        Content="Batal"
                        Command="{Binding CancelCommand}"
                        Height="36"
                        IsEnabled="{Binding !IsBusy}" />
                <Button Grid.Column="1"
                        Content="Simpan"
                        Command="{Binding SaveCommand}"
                        Height="36"
                        Background="#1565C0"
                        Foreground="White"
                        FontWeight="SemiBold"
                        IsEnabled="{Binding !IsBusy}" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
